# ──────────────────────────────────────────────────────────────────────────────
# AI Tools Hub Environment Variables
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Site Configuration ────────────────────────────────────────────────────────
# Required: Set this to your production domain for proper SEO and social sharing
NEXT_PUBLIC_SITE_URL=https://www.aireviewstack.org

# ── Analytics & Tracking ──────────────────────────────────────────────────────
# Optional: Google Analytics 4 Property ID
# Get this from: Google Analytics → Admin → Property → Data Streams → Web Stream Details
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Optional: Google Search Console verification code
# Get this from: Google Search Console → Settings → Verification
# Example: abc123def456
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Content Generation (Agents) ───────────────────────────────────────────────
# Required for autonomous article generation
# Get this from: https://console.groq.com → API Keys
GROQ_API_KEY=

# GitHub personal access token for publishing articles
# Get this from: GitHub → Settings → Developer settings → Personal access tokens (classic)
# Scopes needed: repo (full control)
GITHUB_TOKEN=

# GitHub repository where articles will be published
# Format: owner/repository
GITHUB_REPO=

# ── Email Configuration (Optional) ────────────────────────────────────────────
# Used for contact form and notification emails
# Supported providers: SMTP, SendGrid, Resend, Mailgun

# SMTP Configuration (if using SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# SendGrid API Key (if using SendGrid)
# SENDGRID_API_KEY=SG.xxx

# ── Security ──────────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated)
NEXT_PUBLIC_ALLOWED_ORIGINS=https://www.aireviewstack.org

# API rate limiting (requests per minute)
API_RATE_LIMIT=100

# ── Development ───────────────────────────────────────────────────────────────
# Set to 'production' for optimized builds
NODE_ENV=production

# Enable debug logging
DEBUG=false
